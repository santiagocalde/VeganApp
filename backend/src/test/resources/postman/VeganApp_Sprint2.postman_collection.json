              "host": ["{{baseUrl}}"],
              "path": ["plates", "options"],
              "query": [
                {
                  "key": "category",
                  "value": "PROTEIN"
                }
              ]
            }
          }
        },
        {
          "name": "POST /plates/calculate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const result = pm.response.json().data;",
                  "pm.test('Tiene totales nutricionales', () => {",
                  "    pm.expect(result).to.have.property('totalCalories');",
                  "    pm.expect(result).to.have.property('totalProteinG');",
                  "    pm.expect(result).to.have.property('isBalanced');",
                  "});",
                  "pm.test('Tiene reacción de Pippin', () => {",
                  "    pm.expect(result.pippinReaction).to.have.property('message');",
                  "    pm.expect(result.pippinReaction.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
