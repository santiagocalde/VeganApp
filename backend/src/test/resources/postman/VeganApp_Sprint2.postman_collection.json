{
  "info": {
    "_postman_id": "veganapp-sprint2-collection",
    "name": "VeganApp API — Sprint 2",
    "description": "Colección completa para CI/CD con Newman. Ejecutar en orden.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "testEmail",
      "value": "test.sprint2@veganapp.com",
      "type": "string"
    },
    {
      "key": "testPassword",
      "value": "TestPass1234!",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "description": "Preparar el ambiente: registrar usuario y obtener token",
      "item": [
        {
          "name": "POST Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response tiene estructura correcta', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data).to.have.property('accessToken');",
                  "    pm.expect(json.data.user.id).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{testEmail}}\",\"password\":\"{{testPassword}}\",\"name\":\"Test User Sprint2\",\"profileType\":\"VEGAN\",\"motivation\":\"HEALTH\",\"timezone\":\"UTC\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('AccessToken presente', () => {",
                  "    pm.expect(json.data.accessToken).to.be.a('string');",
                  "});",
                  "pm.collectionVariables.set('bearerToken', json.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "pm.collectionVariables.set('userId', json.data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{testEmail}}\",\"password\":\"{{testPassword}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "POST /auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Nuevo accessToken', () => {",
                  "    const newToken = pm.response.json().data.accessToken;",
                  "    pm.expect(newToken).to.be.a('string');",
                  "    pm.collectionVariables.set('bearerToken', newToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "POST /auth/logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. User Profile",
      "item": [
        {
          "name": "GET /users/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const user = pm.response.json().data;",
                  "pm.test('Perfil tiene campos obligatorios', () => {",
                  "    pm.expect(user).to.have.property('id');",
                  "    pm.expect(user).to.have.property('email');",
                  "    pm.expect(user).to.have.property('name');",
                  "});",
                  "pm.test('No expone passwordHash', () => {",
                  "    pm.expect(pm.response.text()).to.not.include('passwordHash');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "PUT /users/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Nombre actualizado', () => {",
                  "    pm.expect(pm.response.json().data.name).to.equal('Usuario Test Actualizado');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Usuario Test Actualizado\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "PUT /users/me/tone",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"tone\":\"SARCASTIC\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/me/tone",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me", "tone"]
            }
          }
        },
        {
          "name": "GET /users/badges",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const badges = pm.response.json().data;",
                  "pm.test('Badge STREAK_7 existe', () => {",
                  "    pm.expect(badges.some(b => b.code === 'STREAK_7')).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/badges",
              "host": ["{{baseUrl}}"],
              "path": ["users", "badges"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Streak & Check-in",
      "item": [
        {
          "name": "GET /streaks/me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const streak = pm.response.json().data;",
                  "pm.test('Tiene currentDays', () => {",
                  "    pm.expect(streak).to.have.property('currentDays');",
                  "    pm.expect(streak.currentDays).to.be.at.least(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/streaks/me",
              "host": ["{{baseUrl}}"],
              "path": ["streaks", "me"]
            }
          }
        },
        {
          "name": "POST /streaks/checkin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 o 409', () => {",
                  "    pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json().data;",
                  "    pm.test('Tiene pippinReaction', () => {",
                  "        pm.expect(data.pippinReaction).to.have.property('message');",
                  "        pm.expect(data.pippinReaction).to.have.property('animationState');",
                  "    });",
                  "} else if (pm.response.code === 409) {",
                  "    pm.test('409 indica ya hizo check-in', () => {",
                  "        pm.expect(pm.response.json().error.code).to.equal('STREAK_001');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"category\":\"FOOD\",\"notes\":\"Test check-in desde Postman\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/streaks/checkin",
              "host": ["{{baseUrl}}"],
              "path": ["streaks", "checkin"]
            }
          }
        }
      ]
