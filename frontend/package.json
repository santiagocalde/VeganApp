{
  "name": "veganapp-mobile",
  "version": "0.1.0",
  "description": "VeganApp - React Native 0.74 Mobile Application",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}'",
    "start": "react-native start",
    "build:android": "cd android && ./gradlew clean assembleDebug",
    "build:ios": "cd ios && xcodebuild -workspace VeganApp.xcworkspace -scheme VeganApp -configuration Release"
  },
  "dependencies": {
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-firebase/messaging": "^20.0.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.3.29",
    "axios": "^1.6.8",
    "date-fns": "^3.6.0",
    "react": "18.2.0",
    "react-hook-form": "^7.51.0",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-mmkv": "^2.10.2",
    "react-native-reanimated": "^2.17.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "~3.31.1",
    "react-native-svg": "15.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.74.85",
    "@react-native/eslint-config": "0.74.85",
    "@react-native/metro-config": "0.74.85",
    "@react-native/typescript-config": "0.74.85",
    "@tsconfig/react-native": "^3.0.2",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.48",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-transformer": "0.77.0",
    "prettier": "^3.1.1",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native"
  }
}
