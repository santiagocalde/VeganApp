    {
      "name": "5. Plate Builder",
      "item": [
        {
          "name": "GET /plates/options?category=BASE",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const options = pm.response.json().data;",
                  "pm.test('Hay opciones de base', () => {",
                  "    pm.expect(options.length).to.be.above(0);",
                  "    pm.expect(options[0].category).to.equal('BASE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/plates/options?category=BASE",
              "host": ["{{baseUrl}}"],
              "path": ["plates", "options"],
              "query": [
                {
                  "key": "category",
                  "value": "BASE"
                }
              ]
            }
          }
        },
        {
          "name": "GET /plates/options?category=PROTEIN",
          "event": [
