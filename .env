# ═════════════════════════════════════════════════════════════
# VeganApp Environment Configuration
# ═════════════════════════════════════════════════════════════

# ─── Backend Networking ──────────────────────────────────────
# 0.0.0.0 = Listen on all interfaces (required for emulator/Docker)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# ─── Database ────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=veganapp
DB_USERNAME=veganapp_user
DB_PASSWORD=dev_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── MinIO (Object Storage) ──────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Monitoring ──────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ─── Spring Boot Profile ─────────────────────────────────────
SPRING_PROFILE=dev
